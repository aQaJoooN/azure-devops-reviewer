# Environment Configuration Example
# Copy this file to .env and fill in your values

# Application Environment
AZR_ENV=development
AZR_DEBUG=1
AZR_TESTING=0

# Logging Configuration
AZR_LOG_LEVEL=DEBUG

# HTTP Request Settings
AZR_TIMEOUT=60
AZR_RETRY=3

# Azure DevOps Configuration
AZR_AZURE_TOKEN=your_azure_devops_personal_access_token_here

# AI API Configuration (for future use)
AZR_AI_URL=https://your-ai-api-endpoint.com
AZR_AI_KEY=your_ai_api_key_here
